# secrets — API keys live in .env files, never commit
.env
**/.env

# python
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# node
node_modules/
dist/

# runtime state (SQLite DBs, trained model bundles incl. .prev backups, launch logs)
*.db
*.joblib
*.joblib.*
*.pkl
.logs/
platform/backend/app/data/runtime_settings.json

# editor/os noise
.DS_Store
Thumbs.db
.claude/
.obsidian/
.~lock*#

# project instructions (local, not part of the public product)
/CLAUDE.md

# internal working material — never public (see memory: repo = product only)
#   docs/      cheatsheets, workflows, plans, handoffs, guides
#   research/  memos, daily sweeps, watchlist + tracker
#   archive/   git bundles, source office docs
/docs/
/research/
/archive/

# pre-platform legacy apps (superseded by platform/; kept on disk for reference only)
/capstack/
/hazard/
/fulcrum/

# stray office docs / bundles anywhere (belt-and-suspenders over the dir ignores above)
*.docx
*.xlsx
*.bundle
