# SSR Platform configuration — copy to platform/.env and fill in.
# Every variable is optional except SEC_USER_AGENT; features degrade gracefully without keys.

# REQUIRED. SEC EDGAR demands a descriptive User-Agent ("Name email") or it returns 403.
SEC_USER_AGENT="Your Name you@example.com"

# Optional. Enables LLM extraction of footnotes (covenants, off-balance-sheet items,
# Exhibit 21 subsidiaries). Empty = those phases are skipped gracefully.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Optional. FINRA Query API credentials for the HY market credit backdrop.
FINRA_API_KEY=
FINRA_API_SECRET=

# Defaults shown; override if desired.
HERO_TICKERS=AAL,ATUS,TSE
MARKET_INDEX=SPY
RISK_FREE_RATE=0.04
